<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EchoTimes:Your daily dose of real-time news around the world</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="../style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>
    <header class="Navigation-bar">
        <div id="menu">
            <input type="checkbox" id="menucheck" style="display: none;">
            <label for="menucheck" id="label"><i class="fa-solid fa-bars"></i></label>
            <form action="/Categories" method="get" class="side-menu">
                <button type="submit" class="btn btn-primary mt-2" name="category" value="world">World</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="nation">Nation</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="business">Business</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="technology">Technology</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="entertainment">Entertainment</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="sports">Sports</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="science">Science</button>
                <button type="submit" class="btn btn-primary mt-2" name="category" value="health">Health</button>
            </form>
        </div>
        <div class="logo">
            <svg width="200" height="50" viewBox="0 0 200 60" xmlns="http://www.w3.org/2000/svg">
                <g transform="translate(10,10)">
                    <circle cx="20" cy="20" r="20" fill="#1976d2" />
                    <path d="M10 20 a1,1 0 0,1 0,-8" stroke="#fff" stroke-width="2" fill="none" />
                    <path d="M15 20 a1,1 0 0,1 0,-12" stroke="#fff" stroke-width="2" fill="none" />
                    <path d="M20 20 a1,1 0 0,1 0,-16" stroke="#fff" stroke-width="2" fill="none" />
                </g>
                <text x="60" y="35" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#1976d2">
                    Echo
                    <tspan fill="#212121">Times</tspan>
                </text>
            </svg>
        </div>
        <div class="signup-login" style="font-size: 2rem; color: #f8b500;"><i class="fa-solid fa-circle-user"></i></div>
    </header>
    <main class="News-content">
        <div id="lodincontainer" style="position: inherit; height: 88.8vh; width: 100vw; background-color: #f9f9f9;">
            <div class="loading" id="loadin">
            </div>
            <div class="loading" id="loadin1">
            </div>
            <div class="loading" id="loadin2">
            </div>
        </div>
        <div id="newsnotloaded" class="container" style="display: none;height: 100vh;">
        </div>
        </div>
    </main>
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-logo">
                <h2>📰 EchoTimes</h2>
                <p>Your daily dose of real-time news around the world.</p>
            </div>

            <div class="footer-links">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/general">General</a></li>
                    <li><a href="/sports">Sports</a></li>
                    <li><a href="/technology">Technology</a></li>
                    <li><a href="/business">Business</a></li>
                </ul>
            </div>

            <div class="footer-social">
                <h4>Follow Us</h4>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2025 NewsFlash. All rights reserved.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../app.js"></script>
</body>

</html>